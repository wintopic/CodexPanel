name = "codex-relay"
main = "relay-worker.mjs"
compatibility_date = "2026-06-30"

[[durable_objects.bindings]]
name = "RELAY_SESSION"
class_name = "CodexRelaySession"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["CodexRelaySession"]

[vars]
# Optional. Comma-separated device allowlist. If omitted, any device id can
# connect as an agent.
# DEVICE_IDS = "my-mac"

# Optional tuning values.
# CLIENT_TIMEOUT_MS = "65000"
# AGENT_POLL_TIMEOUT_MS = "25000"
# AGENT_STALE_MS = "45000"
# MAX_BODY_BYTES = "33554432"
